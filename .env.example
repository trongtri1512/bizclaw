# ═══════════════════════════════════════════════════════════════
# BizClaw Platform — Environment Configuration
# Copy this to .env and fill in real values
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=bizclaw
POSTGRES_USER=bizclaw
POSTGRES_PASSWORD=BizClaw@2026DB

# Full connection string (auto-built from above for local docker)
DATABASE_URL=postgres://bizclaw:BizClaw@2026DB@postgres:5432/bizclaw

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=

# ── Admin Default Credentials ────────────────────────────────
ADMIN_EMAIL=admin@bizclaw.vn
ADMIN_PASSWORD=BizClaw@2026

# ── Platform ─────────────────────────────────────────────────
BIZCLAW_BIND_ALL=1
BIZCLAW_BASE_URL=http://localhost:3001
# For production: BIZCLAW_BASE_URL=https://apps.bizclaw.vn

# ── CORS Origins (comma-separated) ───────────────────────────
# For local dev, leave empty. For prod, set your domains:
# BIZCLAW_CORS_ORIGINS=https://bizclaw.vn,https://apps.bizclaw.vn

# ── Timezone ─────────────────────────────────────────────────
TZ=Asia/Ho_Chi_Minh

# ── Logging ─────────────────────────────────────────────────
RUST_LOG=info
# For debug: RUST_LOG=bizclaw_platform=debug,bizclaw=debug
